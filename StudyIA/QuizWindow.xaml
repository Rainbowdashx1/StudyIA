<Window x:Class="StudyIA.QuizWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Evaluaci&#xF3;n" Height="700" Width="840"
        MinWidth="640" MinHeight="560"
        WindowStartupLocation="CenterOwner">

    <Grid>

        <!-- ════════════════════════════════════════ PANEL QUIZ ════════════════════════════════════════ -->
        <Grid x:Name="QuizPanel" Margin="28,22,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- progreso -->
                <RowDefinition Height="Auto"/>   <!-- fuente -->
                <RowDefinition Height="Auto"/>   <!-- pregunta -->
                <RowDefinition Height="*"/>      <!-- respuesta -->
                <RowDefinition Height="Auto"/>   <!-- zona inferior -->
            </Grid.RowDefinitions>

            <!-- Progreso -->
            <Grid Grid.Row="0" Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="ProgressText"
                           FontSize="13" Foreground="#555555"
                           VerticalAlignment="Center" Margin="0,0,14,0"/>
                <ProgressBar x:Name="QuizProgress"
                             Grid.Column="1" Height="8"
                             Minimum="0" Maximum="100"/>
            </Grid>

            <!-- Fuente (archivo + página) -->
            <TextBlock x:Name="SourceText"
                       Grid.Row="1"
                       FontSize="11" Foreground="#888888"
                       Margin="0,0,0,10"/>

            <!-- Pregunta -->
            <Border Grid.Row="2"
                    Background="#EFF6FF" BorderBrush="#BFDBFE"
                    BorderThickness="1" CornerRadius="8"
                    Padding="18,14" Margin="0,0,0,16">
                <TextBlock x:Name="QuestionText"
                           FontSize="15" TextWrapping="Wrap"
                           LineHeight="26"/>
            </Border>

            <!-- Respuesta -->
            <Grid Grid.Row="3">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <TextBlock Text="Tu respuesta:"
                           FontWeight="SemiBold" FontSize="13"
                           Margin="0,0,0,6"/>
                <TextBox x:Name="AnswerBox"
                         Grid.Row="1"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         Padding="12" FontSize="13"
                         BorderBrush="#CCCCCC"
                         ToolTip="Ctrl+Enter para enviar"
                         KeyDown="AnswerBox_KeyDown"/>
            </Grid>

            <!-- Zona inferior: botón responder + panel de feedback -->
            <Grid Grid.Row="4" Margin="0,14,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Botón + spinner -->
                <StackPanel Grid.Row="0" Orientation="Horizontal" HorizontalAlignment="Right">
                    <StackPanel x:Name="EvaluatingPanel"
                                Orientation="Horizontal"
                                Visibility="Collapsed"
                                VerticalAlignment="Center"
                                Margin="0,0,16,0">
                        <TextBlock Text="Evaluando&#x2026;"
                                   FontSize="13" Foreground="#555555"
                                   VerticalAlignment="Center"/>
                        <ProgressBar IsIndeterminate="True"
                                     Width="90" Height="8"
                                     Margin="10,0,0,0"
                                     VerticalAlignment="Center"/>
                    </StackPanel>
                    <Button x:Name="AnswerBtn"
                            Content="Responder  &#x2192;"
                            Height="36" Padding="22,0"
                            Background="#0078D4" Foreground="White"
                            FontWeight="SemiBold" FontSize="13"
                            Click="Answer_Click"/>
                </StackPanel>

                <!-- Feedback -->
                <Border x:Name="FeedbackPanel"
                        Grid.Row="1"
                        Visibility="Collapsed"
                        Margin="0,14,0,0"
                        Background="#F8F8F8"
                        BorderBrush="#E0E0E0" BorderThickness="1"
                        CornerRadius="8" Padding="16,14">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- Círculo de puntuación -->
                        <Border x:Name="ScoreBadge"
                                Grid.Column="0"
                                Width="62" Height="62"
                                CornerRadius="31"
                                Margin="0,0,16,0">
                            <TextBlock x:Name="ScoreText"
                                       FontSize="19" FontWeight="Bold"
                                       Foreground="White"
                                       HorizontalAlignment="Center"
                                       VerticalAlignment="Center"/>
                        </Border>

                        <!-- Texto de retroalimentación -->
                        <TextBlock x:Name="FeedbackText"
                                   Grid.Column="1"
                                   TextWrapping="Wrap"
                                   FontSize="13"
                                   VerticalAlignment="Center"/>

                        <!-- Botón siguiente / ver resultados -->
                        <Button x:Name="NextBtn"
                                Grid.Column="2"
                                Height="36" Padding="20,0"
                                Margin="16,0,0,0"
                                Foreground="White"
                                FontWeight="SemiBold" FontSize="13"
                                Click="Next_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>


        <!-- ════════════════════════════════════════ PANEL RESULTADOS ════════════════════════════════════════ -->
        <Grid x:Name="ResultsPanel" Visibility="Collapsed" Margin="28,22,28,22">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>   <!-- título + media -->
                <RowDefinition Height="*"/>      <!-- tabla -->
                <RowDefinition Height="Auto"/>   <!-- botón cerrar -->
            </Grid.RowDefinitions>

            <!-- Encabezado -->
            <StackPanel Grid.Row="0" Margin="0,0,0,18">
                <TextBlock Text="&#x2705;  Evaluaci&#xF3;n completada"
                           FontSize="20" FontWeight="Bold" Margin="0,0,0,10"/>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="Puntuaci&#xF3;n media:"
                               FontSize="14" VerticalAlignment="Center"
                               Margin="0,0,12,0"/>
                    <Border x:Name="AvgBadge" CornerRadius="20" Padding="20,8">
                        <TextBlock x:Name="AvgText"
                                   FontSize="16" FontWeight="Bold"
                                   Foreground="White"/>
                    </Border>
                </StackPanel>
            </StackPanel>

            <!-- Tabla de resultados -->
            <DataGrid Grid.Row="1" x:Name="ResultsGrid"
                      AutoGenerateColumns="False"
                      IsReadOnly="True"
                      CanUserAddRows="False"
                      CanUserDeleteRows="False"
                      GridLinesVisibility="Horizontal"
                      BorderThickness="1" BorderBrush="#CCCCCC"
                      RowBackground="White" AlternatingRowBackground="#F9F9F9"
                      HeadersVisibility="Column"
                      SelectionMode="Single"
                      RowHeight="56">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="#"
                                        Binding="{Binding Number}"
                                        Width="40"/>
                    <DataGridTextColumn Header="Pregunta"
                                        Binding="{Binding Question}"
                                        Width="*" MinWidth="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping"  Value="Wrap"/>
                                <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Tu respuesta"
                                        Binding="{Binding UserAnswer}"
                                        Width="*" MinWidth="120">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping"  Value="Wrap"/>
                                <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Puntuaci&#xF3;n"
                                        Binding="{Binding ScoreDisplay}"
                                        Width="90">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="FontWeight" Value="SemiBold"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                    <DataGridTextColumn Header="Retroalimentaci&#xF3;n"
                                        Binding="{Binding Feedback}"
                                        Width="220">
                        <DataGridTextColumn.ElementStyle>
                            <Style TargetType="TextBlock">
                                <Setter Property="TextWrapping"  Value="Wrap"/>
                                <Setter Property="TextTrimming"  Value="CharacterEllipsis"/>
                                <Setter Property="VerticalAlignment" Value="Center"/>
                            </Style>
                        </DataGridTextColumn.ElementStyle>
                    </DataGridTextColumn>
                </DataGrid.Columns>
            </DataGrid>

            <!-- Botón cerrar -->
            <StackPanel Grid.Row="2" Orientation="Horizontal"
                        HorizontalAlignment="Right" Margin="0,14,0,0">
                <Button Content="Cerrar"
                        Width="90" Height="32"
                        Click="CloseResult_Click"/>
            </StackPanel>
        </Grid>
    </Grid>
</Window>
